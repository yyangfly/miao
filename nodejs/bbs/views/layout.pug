doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title= title
    link(rel='stylesheet', href='/stylesheets/style.css')
  body
    .container
      header.topbar
        a.brand(href='/') BBS
        nav.nav
          if currentUser
            span.user 你好，#{currentUser.username}
            form(action='/logout', method='post')
              button(type='submit') 退出
          else
            a(href='/login') 登录
            a(href='/register') 注册
      block content
